# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# WebSocket Configuration
NEXT_PUBLIC_WS_URL=ws://localhost:6001
NEXT_PUBLIC_WS_KEY=your-reverb-app-key
NEXT_PUBLIC_WS_CLUSTER=mt1

# App Configuration
NEXT_PUBLIC_APP_NAME=Bravos
